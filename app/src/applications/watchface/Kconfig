menu "Watchface"
    config WATCHFACE_DIGITAL
        bool
        prompt "Add digital watchface"
        default y

    config WATCHFACE_DIGITAL_MINIMAL
        bool
        prompt "Add digital minimal watchface"
        default y

    config WATCHFACE_MINIMAL
        bool
        prompt "Add minimal watchface"
        default y
endmenu
